# ============================================================
# magical-planet — variables de entorno
# ============================================================
# Copiar a .env y rellenar. NUNCA commitear .env.
# Para producción: setear en Vercel dashboard o via `vercel env add`.

# ------------------------------------------------------------
# Supabase (cliente — expuesto al frontend, seguro por RLS)
# ------------------------------------------------------------
# Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# Settings → API → anon/public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ------------------------------------------------------------
# Solo para scripts locales / migrations (NO subir al cliente)
# ------------------------------------------------------------
# Settings → Database → Connection string (URI mode)
# Se usa en scripts/migrate.sh para ejecutar migrations via psql
SUPABASE_DB_URL=postgresql://postgres:<password>@db.xxxxxxxxxxxxxxxx.supabase.co:5432/postgres

# Settings → API → service_role (SECRETO, administrar DB)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Project reference (parte del URL supabase, subdominio)
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Vercel (deploy)
# ------------------------------------------------------------
# vercel.com/account/tokens — scope "Full account"
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tras `vercel link` (.vercel/project.json)
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxx
VERCEL_ORG_ID=team_xxxxxxxxxxxxx

# ------------------------------------------------------------
# Google OAuth (Auth Supabase)
# ------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Redirect URI: https://<ref>.supabase.co/auth/v1/callback
# Se pegan en Supabase Dashboard → Authentication → Providers → Google
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# ------------------------------------------------------------
# GitLab (repo + CI)
# ------------------------------------------------------------
# gitlab.com/-/profile/personal_access_tokens — scope: api, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxx
GITLAB_PROJECT_URL=https://gitlab.com/tu-usuario/magical-planet

# ------------------------------------------------------------
# APIs externas opcionales (features futuros)
# ------------------------------------------------------------
# OpenWeather (clima integrado B.10)
# OPENWEATHER_API_KEY=

# Sentry (error tracking K.47)
# SENTRY_DSN=

# PostHog (analytics K.47)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
